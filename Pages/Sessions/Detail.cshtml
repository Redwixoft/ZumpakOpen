@page
@model ZumpakOpen.Pages.Sessions.DetailModel
@{
    ViewData["Title"] = Model.Session.Name;
}

<a asp-page="/Index" class="page-link-back text-muted d-inline-block mb-3">← All sessions</a>

<div class="d-flex justify-content-between align-items-center mb-1">
    <h4 class="mb-0">@Model.Session.Name</h4>
</div>
<p class="text-muted mb-3">@Model.Session.Date.ToString("d. M. yyyy")</p>

<h6 class="text-uppercase text-muted mb-2" style="font-size:.75rem; letter-spacing:.08em;">Players</h6>
<div class="list-group mb-4">
    @foreach (var p in Model.Participants)
    {
        <div class="list-group-item d-flex justify-content-between align-items-center py-2">
            <span class="fw-semibold">@p.Name</span>
            <span class="badge bg-success rounded-pill">@p.Wins win@(p.Wins == 1 ? "" : "s")</span>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h6 class="text-uppercase text-muted mb-0" style="font-size:.75rem; letter-spacing:.08em;">Matches</h6>
    <a asp-page="/Matches/Create" asp-route-sessionId="@Model.Session.Id" class="btn btn-success btn-sm px-3">+ New match</a>
</div>

@if (!Model.Matches.Any())
{
    <p class="text-muted small">No matches yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var m in Model.Matches)
        {
            <a asp-page="/Matches/Detail" asp-route-id="@m.Id"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                <div>
                    <div class="fw-semibold">Match #@m.MatchNumber</div>
                    <small class="text-muted">First to @m.WinningThreshold pts</small>
                </div>
                @if (m.IsFinished)
                {
                    <span class="badge bg-success">@m.WinnerName</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">In progress</span>
                }
            </a>
        }
    </div>
}
